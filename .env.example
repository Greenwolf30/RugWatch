# Copy to .env â€” NEVER upload .env to GitHub

HELIUS_API_KEY=
# BIRDEYE_API_KEY=
# SOLSCAN_API_KEY=

# Manual-only scan (default). 1 = old auto-flag on scan
# RUGWATCH_AUTO_FLAG=0

# === Whole project on GitHub (ONE place for code + wallets) ===
RUGWATCH_CLOUD=repo
RUGWATCH_CLOUD_PRIMARY=1
RUGWATCH_GITHUB_REPO=YourUser/RugWatch
GITHUB_TOKEN=ghp_xxxxxxxx
RUGWATCH_GITHUB_PATH=data/wallets_cloud.json
RUGWATCH_GITHUB_BRANCH=main

# Legacy separate Gist (not recommended if you want one folder):
# RUGWATCH_CLOUD=gist
# RUGWATCH_GIST_ID=

# Website (python run_web.py) — never put keys in web/config.js
WEB_API_TOKEN=
WEB_HOST=127.0.0.1
WEB_PORT=8787
WEB_CORS_ORIGINS=*

