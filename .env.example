# Copy to .env — NEVER upload .env to GitHub

HELIUS_API_KEY=
# BIRDEYE_API_KEY=
# SOLSCAN_API_KEY=

# Manual-only scan (default). 1 = old auto-flag on scan
# RUGWATCH_AUTO_FLAG=0

# === Whole project on GitHub (ONE place for code + wallets) ===
RUGWATCH_CLOUD=repo
RUGWATCH_CLOUD_PRIMARY=1
RUGWATCH_GITHUB_REPO=YourUser/RugWatch
GITHUB_TOKEN=ghp_xxxxxxxx
RUGWATCH_GITHUB_PATH=data/wallets_cloud.json
RUGWATCH_GITHUB_BRANCH=main
# Auto-create new cloud JSON files after this many wallets per file
RUGWATCH_CLOUD_SHARD_MAX=100000
RUGWATCH_CLOUD_INDEX=data/wallets_index.json
# Auto-create new local SQLite files after this many wallets per DB
RUGWATCH_LOCAL_DB_MAX=100000

# Legacy separate Gist (not recommended if you want one folder):
# RUGWATCH_CLOUD=gist
# RUGWATCH_GIST_ID=

# Website (python run_web.py) � never put keys in web/config.js
WEB_API_TOKEN=
WEB_HOST=127.0.0.1
WEB_PORT=8787
WEB_CORS_ORIGINS=*

